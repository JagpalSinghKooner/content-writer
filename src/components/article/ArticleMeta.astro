---
interface Props {
  dateCreated: Date | string;
  dateUpdated?: Date | string;
  wordCount?: number;
  author?: string;
}

const {
  dateCreated,
  dateUpdated,
  wordCount = 0,
  author = 'Nicola Maria Rose',
} = Astro.props;

// Format dates
const formatDate = (date: Date | string) => {
  const d = typeof date === 'string' ? new Date(date) : date;
  return d.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
};

// Calculate reading time
const readingTime = Math.ceil(wordCount / 200);

// Check if updated date is different from created
const showUpdated = dateUpdated && formatDate(dateUpdated) !== formatDate(dateCreated);
---

<div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate">
  <!-- Author -->
  <span class="flex items-center gap-1.5">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
    </svg>
    {author}
  </span>

  <span class="text-mist">|</span>

  <!-- Date -->
  <span class="flex items-center gap-1.5">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    <time datetime={typeof dateCreated === 'string' ? dateCreated : dateCreated.toISOString()}>
      {formatDate(dateCreated)}
    </time>
    {showUpdated && (
      <span class="text-mist">
        (Updated {formatDate(dateUpdated)})
      </span>
    )}
  </span>

  {readingTime > 0 && (
    <>
      <span class="text-mist">|</span>

      <!-- Reading time -->
      <span class="flex items-center gap-1.5">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {readingTime} min read
      </span>
    </>
  )}
</div>
