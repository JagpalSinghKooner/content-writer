---
interface Props {
  variant?: 'compact' | 'full';
  showLink?: boolean;
}

const {
  variant = 'full',
  showLink = true,
} = Astro.props;

const credentials = [
  'Certified Neurodivergent Inclusive Coach',
  'ADHD Coach',
  'Sound Therapy Practitioner',
];
---

{variant === 'compact' ? (
  <div class="flex items-center gap-3">
    <div class="w-10 h-10 rounded-full bg-sage-100 flex items-center justify-center text-sage-600 font-heading font-semibold">
      NR
    </div>
    <div>
      <p class="text-sm font-medium text-ink">Nicola Maria Rose</p>
      <p class="text-xs text-slate">Neurodivergent Inclusive Coach</p>
    </div>
  </div>
) : (
  <div class="author-card">
    <div class="flex-shrink-0">
      <div class="w-20 h-20 rounded-full bg-sage-100 flex items-center justify-center text-sage-600 font-heading text-2xl font-semibold">
        NR
      </div>
    </div>
    <div class="flex-1">
      <h3 class="font-heading text-lg font-semibold text-ink mb-1">
        Nicola Maria Rose
      </h3>
      <p class="text-slate text-sm mb-3">
        With seven years of experience working with families of neurodivergent children, Nicola created HushAway to provide the gentle sound support she saw so many families needing.
      </p>
      <div class="flex flex-wrap gap-2 mb-3">
        {credentials.map((credential) => (
          <span class="text-xs bg-sage-50 text-sage-600 px-2 py-1 rounded-full">
            {credential}
          </span>
        ))}
      </div>
      {showLink && (
        <a
          href="/author/nicola"
          class="text-sm text-sage-600 hover:text-sage-700 font-medium inline-flex items-center gap-1 transition-colors"
        >
          Learn more about Nicola
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      )}
    </div>
  </div>
)}
