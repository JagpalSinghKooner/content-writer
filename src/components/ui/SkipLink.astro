---
interface Props {
  href?: string;
  label?: string;
}

const {
  href = '#main-content',
  label = 'Skip to main content',
} = Astro.props;
---

<a
  href={href}
  class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:bg-sage focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-medium focus:outline-none"
>
  {label}
</a>
